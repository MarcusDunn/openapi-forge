{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "generator-typescript-fetch config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "packageName": {
      "type": "string",
      "default": "api-client",
      "description": "Value placed in package.json `name`."
    },
    "baseUrl": {
      "type": "string",
      "description": "Default base URL embedded in the generated client. Falls back to the first server URL in the spec, or the empty string."
    }
  }
}
