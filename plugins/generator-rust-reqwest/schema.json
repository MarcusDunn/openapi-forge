{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "generator-rust-reqwest config",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "crateName": {
      "type": "string",
      "default": "api-client",
      "description": "Name placed in the generated `Cargo.toml` `[package].name`."
    },
    "baseUrl": {
      "type": "string",
      "description": "Default base URL embedded in the generated client. Falls back to the first server URL in the spec, or the empty string."
    }
  }
}
