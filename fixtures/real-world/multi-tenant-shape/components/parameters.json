{
  "TenantSlug": {
    "name": "tenant",
    "in": "path",
    "required": true,
    "description": "Tenant identifier (lower-kebab-case).",
    "schema": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    }
  },
  "Page": {
    "name": "page",
    "in": "query",
    "required": false,
    "schema": { "type": "integer", "format": "int32" }
  },
  "Limit": {
    "name": "limit",
    "in": "query",
    "required": true,
    "description": "Page size; intentionally required so the generated CLI exercises the typed-opts path on a required keyword arg.",
    "schema": { "type": "integer", "format": "int32" }
  }
}
