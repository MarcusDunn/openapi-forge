{
  "openapi": "3.0.3",
  "info": { "title": "security-openid-connect", "version": "1.0.0" },
  "paths": {
    "/me": {
      "get": {
        "operationId": "getMe",
        "security": [{ "oidc": ["openid", "profile"] }],
        "responses": { "200": { "description": "ok" } }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oidc": {
        "type": "openIdConnect",
        "openIdConnectUrl": "https://auth.example.com/.well-known/openid-configuration"
      }
    }
  }
}
