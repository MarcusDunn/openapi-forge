{
  "openapi": "3.0.3",
  "info": { "title": "body-form-urlencoded", "version": "1" },
  "servers": [{ "url": "https://api.example.com" }],
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string", "format": "password" },
                  "remember": { "type": "boolean" },
                  "redirect_uri": { "type": "string", "format": "uri" }
                }
              },
              "encoding": {
                "redirect_uri": {
                  "allowReserved": true
                }
              }
            }
          }
        },
        "responses": {
          "204": { "description": "ok" }
        }
      }
    }
  }
}
