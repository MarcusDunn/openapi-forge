{
  "openapi": "3.0.3",
  "info": { "title": "security-oauth2-client-credentials", "version": "1" },
  "servers": [{ "url": "https://api.example.com" }],
  "paths": {
    "/me": {
      "get": {
        "operationId": "getMe",
        "responses": {
          "200": { "description": "ok" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2Auth": {
        "type": "oauth2",
        "description": "Machine-to-machine flow — clientCredentials only.",
        "flows": {
          "clientCredentials": {
            "tokenUrl": "https://auth.example.com/token",
            "scopes": { "read": "Read access" }
          }
        }
      }
    }
  }
}
