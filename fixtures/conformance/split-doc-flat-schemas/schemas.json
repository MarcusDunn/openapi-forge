{
  "Pet": {
    "type": "object",
    "required": ["id", "name"],
    "properties": {
      "id": { "type": "string" },
      "name": { "type": "string" },
      "owner": { "$ref": "#/Owner" }
    }
  },
  "Owner": {
    "type": "object",
    "required": ["name"],
    "properties": { "name": { "type": "string" } }
  }
}
